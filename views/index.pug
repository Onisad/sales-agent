doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(name="robots" content="noindex, nofollow")
    title Onisad Sales Assistant
    link(rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📷</text></svg>")
    link(rel="stylesheet" href="/css/style.css")

    body
      .container
        include partials/header
        
        .content
          .connection-alert#connectionAlert(role="alert" style="display: none;")
            .connection-alert-inner
              span.connection-alert-icon
              p.connection-alert-text#connectionAlertText
              button.btn.btn-sm.connection-alert-retry#connectionAlertRetry(type="button") Retry connection
          include partials/camera
          include partials/product-title
          
          // Identify Product Button (visible before identification starts)
          .product-identification-start#productIdentificationStart
            button.btn.btn-primary#identifyProduct(disabled) Identify Product
          
          include partials/hints
          include partials/queue
          include partials/loading
          include partials/logs
        
        .results#results
          include partials/results-camera
          include partials/product-identification
          include partials/pricing
          include partials/sales-text
          include partials/email-confirmation
          include partials/item-created
        
        // Generate Pricing button (moved below results - now handled in product-identification.pug)


    script(src='/js/utils.js')
    script(src='/js/queue.js')
    script(src='/js/camera.js')
    script(src='/js/product-identification.js')
    script(src='/js/pricing.js')
    script(src='/js/sales-text.js')
    script(src='/js/main.js') 