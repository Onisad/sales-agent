# ── LM Studio (local AI) ──────────────────────────────────────────────────────
# The agentic endpoint (POST /agent/run) uses LM Studio as its LLM provider.
# Start LM Studio, load a model, and enable the local server on port 1234.

LM_STUDIO_URL=http://localhost:1234
LM_STUDIO_MODEL=google/gemma-4-26b-a4b-qat
# LM_STUDIO_PROVIDER_ID=lmstudio        # default, no need to change
# LM_STUDIO_API_KEY=lm-studio           # LM Studio ignores this but SDK requires it

# ── Legacy LLM (Open WebUI / Ollama) ─────────────────────────────────────────
# Still used by the original sequential endpoints (/product, /pricing, /sales).
# Not needed if you only use /agent/run.

OPEN_WEBUI_URL=https://your-open-webui-url
OPEN_WEBUI_API_KEY=sk-your-api-key
TEXT_MODEL=your-text-model-name
VISION_MODEL=your-vision-model-name

# ── Google Vision API ─────────────────────────────────────────────────────────
# Optional but recommended — improves product identification.
# The agent's get_vision_labels tool falls back gracefully if this is missing.

GOOGLE_APPLICATION_CREDENTIALS=./google-vision-key.json

# ── Sales site database ───────────────────────────────────────────────────────
SALES_SITE_MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname
SALES_SITE_URL=http://localhost:3004
SALES_SITE_DEFAULT_CATEGORY=Uncategorized
SALES_SITE_DEFAULT_LOCATION=Dublin
SALES_SITE_CONTACT_EMAIL=you@example.com

# ── Cloudflare Access (optional) ──────────────────────────────────────────────
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
